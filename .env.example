# ASM Platform Environment Variables (.env)

# Database Configuration (PostgreSQL)
DB_USER=asm_user
DB_PASSWORD=asm_password_secure
DB_NAME=asm_db
# Host Network 스캐너가 접근할 때 바라보는 호스트 주소
DB_HOST=127.0.0.1
# Docker가 호스트(Ubuntu)에 노출할 포트
HOST_DB_PORT=5432
DB_PORT=5432

# Redis Configuration
HOST_REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# Platform API (Phase 4)
API_PORT=8000
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK_URL_HERE